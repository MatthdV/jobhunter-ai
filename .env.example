# ============================================================
# JobHunter AI — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Gmail API ---
# Create credentials at https://console.cloud.google.com
# Scopes required: gmail.readonly, gmail.send, gmail.modify
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=matthieu@example.com

# --- Telegram Bot ---
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal chat ID (send a message to @userinfobot)
TELEGRAM_CHAT_ID=

# --- LinkedIn (Playwright) ---
# Used for authenticated scraping; store securely
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# --- Database ---
# SQLite (default, local dev) or PostgreSQL for production
DATABASE_URL=sqlite:///./jobhunter.db
# DATABASE_URL=postgresql://user:password@localhost:5432/jobhunter

# --- App Behavior ---
LOG_LEVEL=INFO

# Set to true to preview everything without actually submitting applications
DRY_RUN=true

# Hard cap on applications submitted per day (human safety gate)
MAX_APPLICATIONS_PER_DAY=10

# Minimum AI match score (0–100) to consider an offer worth applying to
MIN_MATCH_SCORE=80

# Claude model to use for scoring and generation
ANTHROPIC_MODEL=claude-opus-4-6
