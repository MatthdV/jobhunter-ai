# ============================================================
# JobHunter AI — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# --- LLM Provider ---
# Which provider to use: anthropic | openai | mistral | deepseek | openrouter
LLM_PROVIDER=anthropic

# Model name — leave empty to use the provider default
# anthropic default: claude-opus-4-6
# openai default:    gpt-4o
# mistral default:   mistral-large-latest
# deepseek default:  deepseek-chat
# openrouter default: openai/gpt-4o
LLM_MODEL=

# --- API Keys (fill in the one(s) you need) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
MISTRAL_API_KEY=...
DEEPSEEK_API_KEY=sk-...
# OpenRouter gives access to 100+ models (Kimi, Llama, Qwen, Gemini, etc.)
OPENROUTER_API_KEY=sk-or-...

# --- Gmail API ---
# Create credentials at https://console.cloud.google.com
# Scopes required: gmail.readonly, gmail.send, gmail.modify
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=

# --- Telegram Bot ---
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your personal chat ID (send a message to @userinfobot)
TELEGRAM_CHAT_ID=

# --- LinkedIn (Playwright) ---
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# --- Database ---
DATABASE_URL=sqlite:///./jobhunter.db
# DATABASE_URL=postgresql://user:password@localhost:5432/jobhunter

# --- App Behavior ---
LOG_LEVEL=INFO
DRY_RUN=true
MAX_APPLICATIONS_PER_DAY=10
MIN_MATCH_SCORE=80

# --- Web / API (required for the FastAPI + Next.js stack) ---
# JWT signing secret — must be at least 32 characters
JWT_SECRET=changeme-min-32-chars-for-hs256-algo

# Fernet key for encrypting user API keys in the database
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=changeme

# NextAuth secret (used by Next.js frontend)
NEXTAUTH_SECRET=changeme

# API URL exposed to the Next.js frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
